# {{ name }} environment variables
# Copy this to .env and fill in your values

# API Keys
OPENAI_API_KEY={{ '' if provider == 'openai' else '# ' }}your-openai-key-here
ANTHROPIC_API_KEY={{ '' if provider == 'anthropic' else '# ' }}your-anthropic-key-here
GEMINI_API_KEY={{ '' if provider == 'gemini' else '# ' }}your-gemini-key-here

# Agent Config
AGENT_NAME={{ name }}
LOG_LEVEL=INFO
PORT=8000
